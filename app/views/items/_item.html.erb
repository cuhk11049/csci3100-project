<div class="head-title">
  <h1>✨ Marketplace</h1>
  <div class="user-actions">
    <p style="font-size: 1.25rem; font-weight: 600; margin-right:40px"> Hello <%= @user.name %>! <p>
    <div class="dropdown">
      <%= link_to "👤 View My Profile", user_path(current_user), class: "dropdown-link" %>
      <%= link_to "🚪 Log Out", logout_path, data: { turbo_method: :delete }, class: "dropdown-link logout" %>
    </div>
  </div>
</div>

<div class="item-detail-container">
  <div class="item-card-detail">
    <div class="item-layout">
      <div class="image-section">
        <% if @item.photo.attached? %>
          <%= image_tag @item.photo, class:"main-image" %>
        <% else %>
          <div class="no-image">
            <div class="no-image-icon">📷</div>
            <p>No image available</p>
          </div>
        <% end %>
      </div>

      <div class="info-section">
        <span class="item-category">
          <%= @item.category %>
        </span>
        
        <h1 class="item-name"><%= @item.name %></h1>
        
        <div class="price-section">
          <div class="price-label">Price</div>
          <div class="price-value">$<%= @item.price %></div>
        </div>
        
        <div class="description-section">
          <div class="description-title">📝 Description</div>
          <div class="description-text"><%= @item.description %></div>
        </div>

        <div class="seller-card">
          <div class="seller-info">
            <h4>
              <%= @item.seller&.name || "Unknown Seller" %>
            </h4>
            <p>Member since <%= @item.seller&.created_at&.strftime("%B %Y") || "Recently" %></p>
          </div>
        </div>

        <div class="meta-info">
          <div class="meta-item">
            <div class="meta-icon">📅</div>
            <div>
              <div class="meta-label">Posted Date</div>
              <div class="meta-value"><%= @item.post_date %></div>
            </div>
          </div>
          <div class="meta-item">
            <div class="meta-icon">👁️</div>
            <div>
              <div class="meta-label">Views</div>
              <div class="meta-value">1 times</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="item-btn-container">
    <div class="item-btn-dummy"></div>
    <%= link_to "Purchase", "#", class: "btn-new item-btn" %>
    <%= link_to "← Back to Market", items_path, class: "btn-new item-btn" %>
    <div class="item-btn-dummy"></div>
  </div>
</div>
