<div class="head-title">
  <div>
    <h1>Marketplace</h1>
    <p>Discover trusted second-hand deals from the CUHK community.</p>
  </div>

  <div class="market-summary">
    <% if current_user&.admin? %>
      <%= link_to '/sidekiq', class: "summary-chip", style: "display: inline-block; padding: 0.5rem 1rem; background: #f3f4f6; border-radius: 9999px; text-decoration: none; color: inherit; margin: 0.5rem 0;" do %>
      <span class="summary-label" style="font-size: 0.75rem; color: #6b7280; margin-right: 0.5rem;">⚙️ Admin Panel</span>
      <strong style="color: #1f2937; font-weight: 600;">Sidekiq</strong>
      <% end %>
    <% end %>
    <div class="summary-chip">
      <span class="summary-label">Items Listed</span>
      <strong><%= @items.count %></strong>
    </div>
    <div class="summary-chip">
      <span class="summary-label">Campus Scope</span>
      <strong>CUHK Only</strong>
    </div>
    <div class="summary-chip">
      <%= link_to "All Locations", locations_path, class: "btn-chip", data: { turbo: false } %>
    </div>
  <div class="user-actions">
    <p style="font-size: 1.25rem; font-weight: 600; margin-right:40px"> Hello <%= @user&.name || "CUHK User" %>! </p>
    <div class="dropdown">
      <% if current_user.present? %>
        <%= link_to "👤 View My Profile", user_path(current_user), class: "dropdown-link" %>
        <%= link_to "⭐ My Favorites", favorites_path, class: "dropdown-link", data: { turbo: false } %>
        <%= link_to "📊 Analytics Dashboard", analytics_path, class: "dropdown-link", data: { turbo: false } %>
        <%= link_to "🚪 Log Out", logout_path, data: { turbo_method: :delete }, class: "dropdown-link logout" %>
      <% end %>
    </div>
  </div>
</div>
</div> 
    
<section class="market-toolbar">
  <%= form_with url: items_path,
    method: :get,
    local: true,
    data: {
      turbo: false,
      controller: "autocomplete",
      autocomplete_url_value: autocomplete_items_path
    },
    class: "filter-form" do %>
    <%= hidden_field_tag :quick_filters,
      @active_quick_filters.join(","),
      data: { autocomplete_target: "quickFilters" } %>
    <div class="filter-grid">
      <div class="filter-field filter-field-wide autocomplete">
        <label for="keyword">Search</label>
        <%= text_field_tag :keyword,
          @search_filters[:keyword],
          id: "keyword",
          class: "filter-input",
          placeholder: "Search by item name, keyword or seller",
          autocomplete: "off",
          role: "combobox",
          aria: {
            autocomplete: "list",
            controls: "keyword-autocomplete-menu",
            expanded: "false"
          },
          data: {
            autocomplete_target: "input",
            action: "input->autocomplete#search keydown->autocomplete#handleKeydown blur->autocomplete#scheduleClose focus->autocomplete#openIfResults"
          } %>
        <div
          id="keyword-autocomplete-menu"
          class="autocomplete-menu"
          data-autocomplete-target="menu"
          hidden
          role="listbox"
          aria-label="Search suggestions"
        >
          <% @autocomplete_suggestions.each do |suggestion| %>
            <button
              type="button"
              class="autocomplete-option"
              data-autocomplete-target="option"
              data-action="mousedown->autocomplete#selectSuggestion"
              data-value="<%= suggestion %>"
              role="option"
            ><%= suggestion %></button>
          <% end %>
        </div>
      </div>

      <div class="filter-field">
        <label for="category">Category</label>
        <%= select_tag :category,
          options_for_select([
            ["All categories", ""],
            ["Electronics", "electronics"],
            ["Furniture", "furniture"],
            ["Clothing", "clothing"],
            ["Books", "books"],
            ["Sports", "sports"],
            ["Other", "other"]
          ], @search_filters[:category]),
          id: "category",
          class: "filter-select" %>
      </div>

      <div class="filter-field">
        <label for="status">Status</label>
        <%= select_tag :status,
          options_for_select([
            ["Any status", ""],
            ["Available", "available"],
            ["Reserved", "reserved"],
            ["Sold", "sold"]
          ], @search_filters[:status]),
          id: "status",
          class: "filter-select" %>
      </div>

      <div class="filter-field">
        <label for="seller_location">College</label>
        <%= select_tag :seller_location,
          options_for_select(
            [["All colleges", ""]] + @seller_locations.map { |location| [location, location] },
            @search_filters[:seller_location]
          ),
          id: "seller_location",
          class: "filter-select" %>
      </div>

      <div class="filter-field">
        <label for="min_price">Min Price</label>
        <%= number_field_tag :min_price, @search_filters[:min_price], id: "min_price", class: "filter-input", placeholder: "0", min: 0 %>
      </div>

      <div class="filter-field">
        <label for="max_price">Max Price</label>
        <%= number_field_tag :max_price, @search_filters[:max_price], id: "max_price", class: "filter-input", placeholder: "5000", min: 0 %>
      </div>

      <div class="filter-field">
        <label for="posted_within_days">Posted Within</label>
        <%= select_tag :posted_within_days,
          options_for_select([
            ["Any time", ""],
            ["Last 3 days", "3"],
            ["Last 7 days", "7"],
            ["Last 30 days", "30"]
          ], @search_filters[:posted_within_days]),
          id: "posted_within_days",
          class: "filter-select" %>
      </div>

      <div class="filter-field">
        <label for="sort">Sort By</label>
        <%= select_tag :sort,
          options_for_select([
            ["Most relevant", "relevance"],
            ["Newest first", "newest"],
            ["Oldest first", "oldest"],
            ["Price: low to high", "price_low_to_high"],
            ["Price: high to low", "price_high_to_low"]
          ], @search_filters[:sort].presence || (@search_filters[:keyword].present? ? "relevance" : "newest")),
          id: "sort",
          class: "filter-select" %>
      </div>
    </div>

    <div class="quick-filters">
      <% under_100_active = @active_quick_filters.include?("under_100") %>
      <% available_now_active = @active_quick_filters.include?("available_now") %>
      <% books_notes_active = @active_quick_filters.include?("books_notes") %>
      <span class="quick-filters-label">Popular filters</span>
      <button
        class="<%= quick_filter_button_classes(under_100_active) %>"
        type="button"
        aria-pressed="<%= under_100_active %>"
        data-action="click->autocomplete#applyQuickFilter"
        data-autocomplete-filter-id-param="under_100"
      >Under $100</button>
      <button
        class="<%= quick_filter_button_classes(available_now_active) %>"
        type="button"
        aria-pressed="<%= available_now_active %>"
        data-action="click->autocomplete#applyQuickFilter"
        data-autocomplete-filter-id-param="available_now"
      >Available Now</button>
      <button
        class="<%= quick_filter_button_classes(books_notes_active) %>"
        type="button"
        aria-pressed="<%= books_notes_active %>"
        data-action="click->autocomplete#applyQuickFilter"
        data-autocomplete-filter-id-param="books_notes"
      >Books & Notes</button>
    </div>

    <div class="filter-actions">
      <%= submit_tag "Search items", class: "btn-new toolbar-btn" %>
      <%= link_to "Clear filters", items_path, class: "btn-secondary" %>
    </div>
  <% end %>
</section>

<p class="search-result-summary">
  Showing <strong><%= @items.count %></strong> result(s)
</p>

<div class="items-grid" id="items-grid">
  <% @items.each do |item| %>
    <div class="item-card" data-item-id="<%= item.id %>" data-category="<%= item.category %>" data-name="<%= item.name.downcase %>">
      <div class="card-head">
        <div class="card-head-left">
          <%= render "favorite_toggle", item: item, favorited: @favorite_item_ids.include?(item.id) %>

          <div class="card-badge">
            <%= item.category %>
          </div>
        </div>
      </div>

        <div class="card-content">
          <h3 class="card-title"><%= item.name %></h3>
          <p class="card-description"><%= truncate(item.description, length: 50) %></p>
          <div class="card-price">$<%= item.price %></div>
          <div class="item-status-badge status-<%= item.status.presence %>">
            <%= item.status.presence || "available" %>
          </div>
          <div class="card-meta">
            <div class="seller-info">
              <span><%= item.seller.name || "Unknown" %></span>
            </div>
            <div>
              <% location_name = item.seller.location.presence || "CUHK" %>
              <% location = Location.find_by(name: location_name) %>
  
              <% if location %>
                <%= link_to location.name, location_path(location), 
                    class: "location-link", data: { turbo: false },
                    style: "text-decoration: none; color: #333; font-weight: 600; display: block; transition: color 0.2s;" %>
              <% else %>
                <%= location_name %>
              <% end %>
            </div>
            <div>
            📅 <%= item.post_date %>
          </div>
        </div>
        <div class="card-link">
          <%= link_to "more info ->", item %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<div class="market-action-row">
  <%= link_to "Post my own item", new_item_path, class: "btn-new" %>
</div>
