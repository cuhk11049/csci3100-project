<%= form_with(model: item, local: true, multipart: true) do |form| %>
  <div class="form-body">
    <% if item.errors.any? %>
      <div id="error_explanation">
      <h2><%= pluralize(item.errors.count, "error") %> prohibited this item from being saved:</h2>
      <ul>
        <% item.errors.full_messages.each do |message| %>
        <li><%= message %></li>
        <% end %>
      </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= form.label :name, class: "form-label" %>
      <%= form.text_field :name, class: "form-control" %>
    </div>

    <div class="form-group">
      <%= form.label :description, class: "form-label" %>
      <%= form.text_area :description, class: "form-control" %>
    </div>

    <div class="form-row">
      <div class="form-group">
        <%= form.label :category, class: "form-label" %>
        <%= form.select :category, 
          options_for_select([
            ["Electronics", "electronics"],
            ["Furniture", "furniture"],
            ["Clothing", "clothing"],
            ["Books", "books"],
            ["Sports", "sports"],
            ["Other", "other"]
            ], item.category),
            { include_blank: "Select a category" },
            { class: "form-select" } %>
        </div>

        <div class="form-group">
          <%= form.label :price, class: "form-label" %>
          <%= form.number_field :price, step: 1, class: "form-control" %>
        </div>
    </div>

    <div class="form-group">
      <%= form.label :seller_name, class: "form-label" %>
      <%= form.text_field :seller_name, class: "form-control", placeholder: "Enter your name" %>
    </div>

    <div class="form-group">
      <%= form.label :photo, "Upload image", class: "form-label" %>
      <%= form.file_field :photo, class: "form-control", accept: "image/*" %>
      <div class="form-text">Accepted formats: JPG, PNG, GIF (Max 5MB)</div>
    </div>

    <div class="form-btn-container">
      <%= form.submit "Post item", class: "btn-new left" %>
      <%= link_to "← Back to Market", items_path, class:"btn-new right" %>
    </div>
  </div>
<% end %>