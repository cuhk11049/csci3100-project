<div class="head-title">
  <h1>✨ Marketplace</h1>
  <p>Discover amazing items from our community!</p>
</div>

<div class="form-container">
  <div class="form-card">
    <div class="form-header">
      <h1>User Login</h1>
      <p>Share your interest with us!</p>
    </div>

    <% if flash[:alert] %>
      <div style="background: #fed7d7; padding: 12px; border-radius: 8px; margin-bottom: 20px; color: #742a2a;">
        ⚠️ <%= flash[:alert] %>
      </div>
    <% end %>

    <% if flash[:notice] %>
      <div style="background: #22a944ff; padding: 12px; border-radius: 8px; margin-bottom: 20px; color: white">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <%= render "form" %>
  </div>
</div>